@rendermode InteractiveServer
@inject IJSRuntime JS

<MudThemeProvider @ref="_themeProvider" Theme="_theme" IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2">GUI-SSH</MudText>
        <MudSpacer />
        @if (!string.IsNullOrEmpty(_activeSessionId))
        {
            <MudChip T="string" Color="Color.Success" Size="Size.Small">Connected</MudChip>
        }
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="ToggleTheme" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Variant="DrawerVariant.Mini"
               ClipMode="DrawerClipMode.Always" OpenMiniOnHover="true">
        <Sidebar ActiveSessionId="@_activeSessionId"
                 OnConnected="HandleConnected"
                 OnSessionSelected="HandleSessionSelected" />
    </MudDrawer>

    <MudMainContent Class="pa-0" Style="overflow: hidden;">
        @if (string.IsNullOrEmpty(_activeSessionId))
        {
            <div class="d-flex align-center justify-center" style="height: 100%;">
                <MudStack AlignItems="AlignItems.Center" Spacing="4">
                    <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Large"
                             Color="Color.Primary" Style="font-size: 4rem;" />
                    <MudText Typo="Typo.h4">GUI-SSH</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary">
                        Select or add a connection from the sidebar to get started.
                    </MudText>
                </MudStack>
            </div>
        }
        else
        {
            <GuiSsh.Components.Layout.SessionTabs SessionId="@_activeSessionId" />
        }
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private string? _activeSessionId;
    private bool _isDarkMode = true;
    private MudThemeProvider _themeProvider = null!;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1e66f5",
            Secondary = "#6c6f85",
            Success = "#40a02b",
            Error = "#d20f39",
            Warning = "#df8e1d",
            Info = "#1e66f5",
            Surface = "#eff1f5",
            Background = "#eff1f5",
            AppbarBackground = "#dce0e8",
            AppbarText = "#4c4f69",
            DrawerBackground = "#e6e9ef",
            DrawerText = "#4c4f69",
            TextPrimary = "#4c4f69",
            TextSecondary = "#6c6f85"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#89b4fa",
            Secondary = "#a6adc8",
            Success = "#a6e3a1",
            Error = "#f38ba8",
            Warning = "#fab387",
            Info = "#89dceb",
            Surface = "#1e1e2e",
            Background = "#1e1e2e",
            AppbarBackground = "#181825",
            AppbarText = "#cdd6f4",
            DrawerBackground = "#181825",
            DrawerText = "#cdd6f4",
            TextPrimary = "#cdd6f4",
            TextSecondary = "#a6adc8"
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "gui-ssh-theme");
            if (saved is "light" or "dark")
            {
                _isDarkMode = saved == "dark";
                await ApplyTheme();
                StateHasChanged();
            }
        }
    }

    private async Task ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
        await ApplyTheme();
        await JS.InvokeVoidAsync("localStorage.setItem", "gui-ssh-theme", _isDarkMode ? "dark" : "light");
    }

    private async Task ApplyTheme()
    {
        await JS.InvokeVoidAsync("eval",
            $"document.documentElement.setAttribute('data-theme', '{(_isDarkMode ? "dark" : "light")}')");
    }

    private void HandleConnected(string sessionId)
    {
        _activeSessionId = sessionId;
        StateHasChanged();
    }

    private void HandleSessionSelected(string sessionId)
    {
        _activeSessionId = sessionId;
        StateHasChanged();
    }
}
