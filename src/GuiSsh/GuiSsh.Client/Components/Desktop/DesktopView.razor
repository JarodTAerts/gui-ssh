@inject ISshService SshService
@inject ShellCommandBuilder CommandBuilder
@inject ShellOutputParser OutputParser
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<div class="desktop-surface" style="position: relative; height: 100%; background: var(--surface-inset); overflow: hidden;">
    @foreach (var window in _windows.Where(w => !w.IsMinimized))
    {
        <DesktopWindow State="@window"
                       OnClose="() => CloseWindow(window)"
                       OnMinimize="() => MinimizeWindow(window)"
                       OnFocus="() => FocusWindow(window)">
            @if (window.Type == WindowType.FileManager)
            {
                <FileManager SessionId="@SessionId"
                             WindowId="@window.Id"
                             OnOpenFile="(path) => OpenFile(path)"
                             OnPathChanged="(path) => OnFileManagerPathChanged(window, path)"
                             OnShowInfo="(entry) => OpenInfoWindow(entry)"
                             OnDownload="(args) => HandleDownload(args.SessionId, args.RemotePath)"
                             OnUpload="(args) => HandleUpload(args.SessionId, args.RemotePath, args.File)" />
            }
            else if (window.Type == WindowType.Editor)
            {
                <EditorWindow SessionId="@SessionId"
                              FilePath="@(window.Data.GetValueOrDefault("FilePath")?.ToString() ?? "")"
                              OnTitleChanged="(title) => { window.Title = title; StateHasChanged(); }" />
            }
            else if (window.Type == WindowType.Info)
            {
                var infoEntry = window.Data.GetValueOrDefault("FileEntry") as FileEntry;
                @if (infoEntry != null)
                {
                    <InfoPanel SessionId="@SessionId" Entry="@infoEntry" />
                }
            }
            else if (window.Type == WindowType.ImageViewer)
            {
                <ImageViewer SessionId="@SessionId"
                             FilePath="@(window.Data.GetValueOrDefault("FilePath")?.ToString() ?? "")" />
            }
            else if (window.Type == WindowType.TaskManager)
            {
                <TaskManager SessionId="@SessionId" />
            }
        </DesktopWindow>
    }

    <Taskbar Windows="@_windows"
             OnWindowClick="ToggleWindow"
             OnNewFileManager="OpenFileManager"
             OnNewTextEditor="OpenBlankEditor"
             OnNewTaskManager="OpenTaskManager" />
</div>

@code {
    [Parameter] public string SessionId { get; set; } = string.Empty;

    private List<DesktopWindowState> _windows = new();
    private int _nextZIndex = 1;
    private IJSObjectReference? _fileTransferModule;

    protected override void OnInitialized()
    {
        // Open a file manager by default
        OpenFileManager();
    }

    private async Task EnsureFileTransferModule()
    {
        _fileTransferModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "/js/file-transfer-interop.js");
    }

    private void OpenFileManager()
    {
        var window = new DesktopWindowState
        {
            Title = "File Manager",
            Type = WindowType.FileManager,
            X = 30 + _windows.Count * 25,
            Y = 30 + _windows.Count * 25,
            Width = 750,
            Height = 500,
            ZIndex = _nextZIndex++
        };
        _windows.Add(window);
    }

    private void OpenFile(string filePath)
    {
        if (ImageViewer.IsImageFile(filePath))
        {
            OpenImageViewer(filePath);
            return;
        }
        OpenFileEditor(filePath);
    }

    private void OpenImageViewer(string filePath)
    {
        var fileName = filePath.Split('/').LastOrDefault() ?? filePath;
        var window = new DesktopWindowState
        {
            Title = $"Image: {fileName}",
            Type = WindowType.ImageViewer,
            X = 90 + _windows.Count * 25,
            Y = 50 + _windows.Count * 25,
            Width = 600,
            Height = 480,
            ZIndex = _nextZIndex++,
            Data = new() { ["FilePath"] = filePath }
        };
        _windows.Add(window);
    }

    private void OpenFileEditor(string filePath)
    {
        var fileName = filePath.Split('/').LastOrDefault() ?? filePath;
        var window = new DesktopWindowState
        {
            Title = $"Editor: {fileName}",
            Type = WindowType.Editor,
            X = 80 + _windows.Count * 25,
            Y = 80 + _windows.Count * 25,
            Width = 650,
            Height = 450,
            ZIndex = _nextZIndex++,
            Data = new() { ["FilePath"] = filePath }
        };
        _windows.Add(window);
    }

    private void OpenBlankEditor()
    {
        var window = new DesktopWindowState
        {
            Title = "Text Editor",
            Type = WindowType.Editor,
            X = 100 + _windows.Count * 25,
            Y = 60 + _windows.Count * 25,
            Width = 650,
            Height = 450,
            ZIndex = _nextZIndex++,
            Data = new() { ["FilePath"] = "" }
        };
        _windows.Add(window);
    }

    private void OpenTaskManager()
    {
        // Only allow one task manager instance
        var existing = _windows.FirstOrDefault(w => w.Type == WindowType.TaskManager);
        if (existing != null)
        {
            existing.IsMinimized = false;
            FocusWindow(existing);
            return;
        }

        var window = new DesktopWindowState
        {
            Title = "Task Manager",
            Type = WindowType.TaskManager,
            X = 60 + _windows.Count * 20,
            Y = 40 + _windows.Count * 20,
            Width = 820,
            Height = 520,
            ZIndex = _nextZIndex++
        };
        _windows.Add(window);
    }

    private void CloseWindow(DesktopWindowState window)
    {
        _windows.Remove(window);
    }

    private void MinimizeWindow(DesktopWindowState window)
    {
        window.IsMinimized = !window.IsMinimized;
    }

    private void FocusWindow(DesktopWindowState window)
    {
        window.ZIndex = _nextZIndex++;
    }

    private void ToggleWindow(DesktopWindowState window)
    {
        if (window.IsMinimized)
        {
            window.IsMinimized = false;
            FocusWindow(window);
        }
        else
        {
            window.IsMinimized = true;
        }
    }

    private void OnFileManagerPathChanged(DesktopWindowState window, string path)
    {
        window.Data["CurrentPath"] = path;
        var dirName = path.Split('/', StringSplitOptions.RemoveEmptyEntries).LastOrDefault() ?? "/";
        window.Title = dirName;
        StateHasChanged();
    }

    private void OpenInfoWindow(FileEntry entry)
    {
        var window = new DesktopWindowState
        {
            Title = $"{entry.Name} — Info",
            Type = WindowType.Info,
            X = 120 + _windows.Count * 20,
            Y = 60 + _windows.Count * 20,
            Width = 380,
            Height = 420,
            ZIndex = _nextZIndex++,
            Data = new() { ["FileEntry"] = entry }
        };
        _windows.Add(window);
        StateHasChanged();
    }

    private async Task HandleDownload(string sessionId, string remotePath)
    {
        try
        {
            var fileName = remotePath.Split('/').LastOrDefault() ?? remotePath;
            Snackbar.Add($"Starting download: {fileName}...", Severity.Info);

            // Use streaming GET endpoint — browser handles the download with native progress bar
            var encodedPath = Uri.EscapeDataString(remotePath);
            var url = $"/api/ssh/download/{sessionId}?path={encodedPath}";

            await EnsureFileTransferModule();
            await _fileTransferModule!.InvokeVoidAsync("downloadFromUrl", url, fileName);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Download failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task HandleUpload(string sessionId, string remotePath, IBrowserFile file)
    {
        try
        {
            // Read up to 100MB — copy to MemoryStream because IBrowserFile streams
            // don't support synchronous reads required by the SSH library
            using var browserStream = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await browserStream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;
            await SshService.UploadFileAsync(sessionId, remotePath, memoryStream, file.Name);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Upload of {file.Name} failed: {ex.Message}", Severity.Error);
        }
    }
}
