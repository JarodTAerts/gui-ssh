@* Draggable/resizable desktop window *@
@inject IJSRuntime JS
@implements IAsyncDisposable

<div @ref="_windowRef" class="desktop-window" tabindex="0"
     style="position: absolute;
            left: @(State.X)px; top: @(State.Y)px;
            width: @(State.Width)px; height: @(State.Height)px;
            z-index: @State.ZIndex;
            display: flex; flex-direction: column;
            background: var(--surface-base); border: 1px solid var(--surface-bright);
            border-radius: 8px; overflow: hidden;
            box-shadow: var(--shadow-lg);"
     @onclick="OnFocus"
     @onclick:stopPropagation="true">

    @* Title Bar — drag handle *@
    <div class="window-titlebar"
         @onpointerdown="OnTitleBarPointerDown"
         style="display: flex; align-items: center; padding: 6px 10px;
                background: var(--surface-container); cursor: move; user-select: none;
                border-bottom: 1px solid var(--surface-bright); flex-shrink: 0; touch-action: none;">
        <MudIcon Icon="@GetWindowIcon()" Size="Size.Small" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.body2" Style="flex: 1; color: var(--on-surface); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
            @State.Title
        </MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Minimize" Size="Size.Small"
                       Color="Color.Default" OnClick="OnMinimize"
                       Style="pointer-events: auto;" />
        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                       Color="Color.Error" OnClick="OnClose"
                       Style="pointer-events: auto;" />
    </div>

    @* Window Content *@
    <div style="flex: 1; overflow: auto; position: relative; display: flex; flex-direction: column;">
        @ChildContent
    </div>

    @* Resize Handles *@
    <div class="resize-handle resize-handle-e"
         @onpointerdown='(e) => OnResizePointerDown(e, "e")'
         @onpointerdown:stopPropagation="true"></div>
    <div class="resize-handle resize-handle-s"
         @onpointerdown='(e) => OnResizePointerDown(e, "s")'
         @onpointerdown:stopPropagation="true"></div>
    <div class="resize-handle resize-handle-se"
         @onpointerdown='(e) => OnResizePointerDown(e, "se")'
         @onpointerdown:stopPropagation="true"></div>
</div>

@code {
    [Parameter] public DesktopWindowState State { get; set; } = new();
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnMinimize { get; set; }
    [Parameter] public EventCallback OnFocus { get; set; }

    private ElementReference _windowRef;
    private IJSObjectReference? _dragModule;
    private DotNetObjectReference<DesktopWindow>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dragModule = await JS.InvokeAsync<IJSObjectReference>("import", "/js/drag-interop.js");
            _dotNetRef = DotNetObjectReference.Create(this);
        }
    }

    private async Task OnTitleBarPointerDown(PointerEventArgs e)
    {
        if (e.Button != 0) return;

        await OnFocus.InvokeAsync();

        if (_dragModule != null && _dotNetRef != null)
        {
            await _dragModule.InvokeVoidAsync("startDrag", _dotNetRef,
                e.ClientX, e.ClientY, State.X, State.Y);
        }
    }

    private async Task OnResizePointerDown(PointerEventArgs e, string direction)
    {
        if (e.Button != 0) return;

        await OnFocus.InvokeAsync();

        if (_dragModule != null && _dotNetRef != null)
        {
            await _dragModule.InvokeVoidAsync("startResize", _dotNetRef,
                e.ClientX, e.ClientY, State.Width, State.Height, direction);
        }
    }

    [JSInvokable]
    public void OnDragMove(double newX, double newY)
    {
        State.X = newX;
        State.Y = newY;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnDragEnd() { }

    [JSInvokable]
    public void OnResizeMove(double newWidth, double newHeight)
    {
        State.Width = newWidth;
        State.Height = newHeight;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnResizeEnd() { }

    private string GetWindowIcon() => State.Type switch
    {
        WindowType.FileManager => Icons.Material.Filled.Folder,
        WindowType.Editor => Icons.Material.Filled.EditNote,
        WindowType.ImageViewer => Icons.Material.Filled.Image,
        WindowType.Info => Icons.Material.Filled.Info,
        WindowType.TaskManager => Icons.Material.Filled.MonitorHeart,
        _ => Icons.Material.Filled.Window
    };

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        try
        {
            if (_dragModule != null)
                await _dragModule.DisposeAsync();
        }
        catch (Microsoft.JSInterop.JSDisconnectedException) { }
    }
}
